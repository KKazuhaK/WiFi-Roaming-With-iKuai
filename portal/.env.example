# .env.example
# Copy to .env next to docker-compose.yml, chmod 600 .env, then run docker compose up -d --build.
#
# This file covers two deployment modes:
#   - Mode A: external reverse proxy (aaPanel Nginx or another proxy); leave COMPOSE_PROFILES empty.
#   - Mode B: built-in Caddy for TLS + DNS-01; set COMPOSE_PROFILES=caddy.

# ============================================================
# Deployment mode switch.
# ============================================================
# Empty = Mode A, Portal only with external TLS reverse proxy.
# caddy = Mode B, Portal + Caddy with automatic Cloudflare DNS-01 certificates.
#COMPOSE_PROFILES=caddy

# ===== Variables used only by Mode B (Caddy) =====

# Cloudflare API Token with only Zone:DNS:Edit, scoped to the kazuhahub.com zone.
# CF Dashboard -> My Profile -> API Tokens -> Create Token -> Edit zone DNS template.
# The same token can be reused by all four sites.
CLOUDFLARE_API_TOKEN=

# LE / ZeroSSL account email for registration and expiry reminders.
ACME_EMAIL=me@kazuha.org

# Public hostname, used for certificate issuance and Caddy virtual host.
PORTAL_HOSTNAME=wifi.login.kazuhahub.com

# HTTPS port Caddy listens on. 28081 avoids 443 conflicts with other host services.
# If changed, also update PUBLIC_URL, Entra Redirect URI, and iKuai captive URL.
PORTAL_HTTPS_PORT=28081

# ============================================================
# Portal configuration required in both modes.
# ============================================================

# ===== Entra ID (Azure AD) =====
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== iKuai cloud custom authentication =====
IKUAI_APPKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

IKUAI_IP_KEYS=user_ip,ip,ipaddr
IKUAI_MAC_KEYS=user_mac,mac,usrmac,devmac
#IKUAI_WEBAUTH_URL=https://portal.ikuai8-wifi.com/Action/webauth-up
#IKUAI_RELEASE_TYPE=1

# iKuai allow-list policy. upload/download are KB/s, 0 means unlimited; timeout is minutes, 0 means never expires.
# Guest-code timeout is not configured here; each code's per-use duration is used on allow-listing.
# These are startup defaults; Admin policy changes are persisted to /data/ikuai-policy.json.
#IKUAI_SSO_UPLOAD=0
#IKUAI_SSO_DOWNLOAD=0
#IKUAI_SSO_TIMEOUT=0
#IKUAI_SSO_COMMENT=
#IKUAI_DUO_UPLOAD=0
#IKUAI_DUO_DOWNLOAD=0
#IKUAI_DUO_TIMEOUT=0
#IKUAI_DUO_COMMENT=
#IKUAI_GUEST_UPLOAD=0
#IKUAI_GUEST_DOWNLOAD=0
#IKUAI_GUEST_COMMENT=

# ===== Duo integration (optional; all five empty disables Duo routing) =====
#
# Requires creating two Applications in the Duo Admin Panel:
#   1. "Auth API"  -> DUO_IKEY / DUO_SKEY                (preauth checks whether the user is in Duo)
#   2. "Web SDK"   → DUO_CLIENT_ID / DUO_CLIENT_SECRET  (Universal Prompt 2FA)
# Both share the same API hostname. All five fields must be set or all empty.
DUO_IKEY=
DUO_SKEY=
DUO_CLIENT_ID=
DUO_CLIENT_SECRET=
DUO_API_HOST=api-XXXXXXXX.duosecurity.com

# Required when Duo is enabled to prevent external domains from triggering Duo pages for employees.
ALLOWED_EMAIL_DOMAINS=kazuha.org,kazuhahub.com,kazuhahub.cn

# ===== Guest-code admin console (optional) =====
# /admin accepts either method, individually or together:
#   - ADMIN_EMAILS      UPN allowlist; direct list, container restart required for changes.
#   - ADMIN_GROUP_IDS   Entra Security Group Object ID (GUID) list; group members become admins.
# If both are empty, /admin is completely disabled.
ADMIN_EMAILS=me@kazuha.org
# Entra Security Group Object ID (GUID). In Entra Admin Center -> Groups, choose the group,
# open Overview, and copy "Object ID". Requires groups claim on the App Registration.
#ADMIN_GROUP_IDS=00000000-0000-0000-0000-000000000000

# Persistent files are written under /data in the container (guest codes, MAC denylist, iKuai policy,
# rate-limit history, event log). Paths are fixed in code. docker-compose.yml bind-mounts /data to
# ./data; change the volume line to move it, no env var needed here.

# ===== Rate limiting / abuse prevention (all optional; empty uses code defaults) =====
# Rule 1: /auth/start counts email failures with dual windows and resets on successful callback.
#AUTH_EMAIL_FAILS_SHORT=5         # Short-window limit.
#AUTH_EMAIL_WINDOW_SHORT=3m       # Short-window duration; supports s/m/h.
#AUTH_EMAIL_FAILS_LONG=20
#AUTH_EMAIL_WINDOW_LONG=1h

# Rule 5: /auth/guest-code counts failures by session MAC and resets on success.
#GUEST_CODE_MAC_FAILS=6
#GUEST_CODE_MAC_WINDOW=30m

# Rule 6: one IP exceeding accumulated failures across endpoints gets a short cooldown.
#IP_FAILS_LIMIT=20
#IP_FAILS_WINDOW=5m
#IP_BAN_DURATION=2m                # Cooldown duration.
#IP_BAN_ESCALATE_AT=999999         # Effectively disables permanent escalation.

# Account-enumeration defense: /auth/start -> opaque token -> /auth/proceed.
#AUTH_PROCEED_TTL=5m

# ===== Event log retention =====
# Default is 7 days; older entries are GC'd by rewriting the JSONL file.
# Convenient for tail -f real-time traffic inspection.
#EVENT_LOG_RETENTION_DAYS=7

# ===== Portal runtime =====
# PUBLIC_URL must exactly match the externally reachable URL, including port for Entra callback matching.
#   Mode A: https://wifi.login.kazuhahub.com        (external reverse proxy on 443)
#   Mode B: https://wifi.login.kazuhahub.com:28081  (Caddy on 28081)
PUBLIC_URL=https://wifi.login.kazuhahub.com

# Portal process listen address.
#   Docker deployment (modes A/B/C): 0.0.0.0:28080, compose maps to host 127.0.0.1:28080.
#   Bare binary + systemd (mode D): 127.0.0.1:28080 directly; proxy to it and do not expose publicly.
LISTEN_ADDR=0.0.0.0:28080

# Persistent file root. Default /data is for containers where docker-compose bind-mounts /data to ./data.
# Bare binary + systemd should use /var/lib/wifi-portal to match systemd ReadWritePaths.
#DATA_DIR=/data

# Container timezone. Default UTC. Admin datetime-local input is parsed in this timezone:
#   TZ=UTC                 -> admin input "18:00" means 18:00 UTC
#   TZ=Asia/Shanghai       -> admin input "18:00" means 18:00 Beijing time
# This also affects log timestamps, CSV export time columns, and admin list display.
#TZ=UTC

# Whether to trust reverse-proxy headers (X-Real-IP / X-Forwarded-For) as client IP. Default true.
# Keep true for production behind TLS-terminating proxy with Portal port not publicly exposed. Set
# false if the Portal port is directly exposed, otherwise attackers can spoof IPs and bypass limits.
# Recommended proxy config: X-Real-IP $remote_addr in nginx or header_up X-Real-IP {remote_host} in Caddy.
# X-Forwarded-For uses the rightmost valid segment, which is the real client IP appended by the proxy.
#TRUST_PROXY=true

# HMAC cookie signing key. Generate once with openssl rand -hex 32. Use the same value to share
# admin cookies across sites after one SSO login; generate separate values for isolation.
SESSION_SECRET=REPLACE_ME_WITH_openssl_rand_hex_32

# ===== Branding =====
BRAND_NAME=Kazuha Hub
BRAND_COLOR=#2563eb
BRAND_LOGO_URL=
