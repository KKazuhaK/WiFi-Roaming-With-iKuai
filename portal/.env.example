# .env.example
# 拷贝这个文件成 .env, 填入真实值, 然后:
#   chmod 600 .env          # 只允许你自己读
#   docker compose up -d    # 起服务
#
# .env 里的 Secret 不能进 git. .gitignore 已经忽略 *.env 但不排除 .env.example

# ===== Entra ID (Azure AD) =====
# Tenant ID: Entra 管理中心 → Overview → Tenant ID
TENANT_ID=00000000-0000-0000-0000-000000000000

# Application (client) ID: App Registration → Overview → Application (client) ID
CLIENT_ID=00000000-0000-0000-0000-000000000000

# Client secret VALUE (不是 ID). 只在 Entra 创建时能看一次, 保存到本地密码管理器.
# 24 个月过期, 到期前要轮换.
CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== iKuai 云自定义认证 =====
# iKuai 云面板 → 自定义认证 → "生成" 按钮得到的 appkey
IKUAI_APPKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 不同固件发过来的 query 字段名不一样, 逗号分隔备选. 一般不用改.
IKUAI_IP_KEYS=user_ip,ip,ipaddr
IKUAI_MAC_KEYS=user_mac,mac,usrmac,devmac

# iKuai 放行接口. 官方文档默认 https, 留空则用默认值.
# 仅当 Phase 4 发现某种固件只接受 http 或要走路由器 LAN IP 时才改.
#IKUAI_WEBAUTH_URL=https://portal.ikuai8-wifi.com/Action/webauth-up

# iKuai 放行 URL 透传参数. 一般不用改.
# custom_name 会出现在 iKuai 审计日志里, 多个对接 portal 时用来区分.
#IKUAI_CUSTOM_NAME=kazuha-hub
#IKUAI_RELEASE_TYPE=1

# user_id 前缀. 非空时 user_id = "{前缀}-{UPN}", 空 = 只送 UPN.
# 设 "Kazuha_Hub" 则 iKuai 审计日志账号列显示 "Kazuha_Hub-me@kazuha.org"
IKUAI_USER_ID_PREFIX=Kazuha_Hub

# ===== Portal 自身 =====
# 对外访问的完整 URL (https). 必须和 App Registration 的 Redirect URI host 一致.
PUBLIC_URL=https://wifi.login.kazuhahub.com

# 容器内监听地址. Docker Compose 把它端口映射到宿主机 127.0.0.1:28080.
# 不用改.
LISTEN_ADDR=0.0.0.0:28080

# 签 cookie 的密钥. 生成: openssl rand -hex 32
# 必须是 64 个 hex 字符 (= 32 字节). 改了会让所有进行中的 OIDC 流程失效.
SESSION_SECRET=REPLACE_ME_WITH_openssl_rand_hex_32

# ===== 品牌化 =====
BRAND_NAME=Kazuha Hub
BRAND_COLOR=#2563eb
# 留空则显示首字母作为 logo. 要自定义 logo 两种方式:
#   (a) 放 static/logo.png 然后设 BRAND_LOGO_URL=/static/logo.png
#   (b) 用外部 CDN, 设 BRAND_LOGO_URL=https://cdn.example.com/logo.png
BRAND_LOGO_URL=
