# .env.example
# 拷贝成 .env (放在 docker-compose.yml 同级), chmod 600 .env, docker compose up -d --build
#
# 这一份文件同时覆盖两种部署模式:
#   - 模式 A: 外部反代 (aaPanel Nginx / 其它), Caddy 不启动 — 下面 COMPOSE_PROFILES 留空
#   - 模式 B: 内置 Caddy 做 TLS + DNS-01, 把 COMPOSE_PROFILES=caddy 打开即可

# ============================================================
# 部署模式开关
# ============================================================
# 留空 = 模式 A (只跑 Portal, 外部反代处理 TLS).
# 设成 caddy = 模式 B (Portal + Caddy, Caddy 自动 Cloudflare DNS-01 拿证书).
#COMPOSE_PROFILES=caddy

# ===== 只有模式 B (Caddy) 会用到的变量 =====

# Cloudflare API Token, 只给 Zone:DNS:Edit 权限, 限定到 example.com zone.
# CF Dashboard → My Profile → API Tokens → Create Token → Edit zone DNS 模板.
# 4 个站点可以复用同一个 token.
CLOUDFLARE_API_TOKEN=

# LE / ZeroSSL 账号注册邮箱, 收到期提醒用.
ACME_EMAIL=you@example.org

# 对外域名 (决定证书申请哪个 + Caddy 反代的 virtual host).
PORTAL_HOSTNAME=wifi.login.example.com

# Caddy 监听的 HTTPS 端口. 28081 是默认, 避开 443 以免跟宿主其他服务冲突.
# 改这里同步改 PUBLIC_URL 和 Entra Redirect URI 和 iKuai captive URL.
PORTAL_HTTPS_PORT=28081

# ============================================================
# Portal 本体配置 (两种模式都要填)
# ============================================================

# ===== Entra ID (Azure AD) =====
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== iKuai 云自定义认证 =====
IKUAI_APPKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

IKUAI_IP_KEYS=user_ip,ip,ipaddr
IKUAI_MAC_KEYS=user_mac,mac,usrmac,devmac
#IKUAI_WEBAUTH_URL=https://portal.ikuai8-wifi.com/Action/webauth-up
#IKUAI_RELEASE_TYPE=1

# iKuai 放行策略. upload/download 单位 KB/s, 0 = 不限速; timeout 单位分钟, 0 = 不过期.
# 访客码 timeout 不手动配置, 放行时使用每个访客码自己的"单次限时".
# 这些是启动默认值; Admin 后台 "放行策略" 页可在线修改, 改动写到 /data/ikuai-policy.json.
#IKUAI_SSO_UPLOAD=0
#IKUAI_SSO_DOWNLOAD=0
#IKUAI_SSO_TIMEOUT=0
#IKUAI_SSO_COMMENT=
#IKUAI_DUO_UPLOAD=0
#IKUAI_DUO_DOWNLOAD=0
#IKUAI_DUO_TIMEOUT=0
#IKUAI_DUO_COMMENT=
#IKUAI_GUEST_UPLOAD=0
#IKUAI_GUEST_DOWNLOAD=0
#IKUAI_GUEST_COMMENT=

# ===== Duo 集成 (可选, 五个值全空则禁用 Duo 分流) =====
#
# 需要在 Duo Admin Panel 创建 **两个** Application:
#   1. "Auth API"  → DUO_IKEY / DUO_SKEY                (preauth 探测用户在不在 Duo)
#   2. "Web SDK"   → DUO_CLIENT_ID / DUO_CLIENT_SECRET  (Universal Prompt 2FA)
# 两个共享同一 API hostname. 五个字段全填或全空.
DUO_IKEY=
DUO_SKEY=
DUO_CLIENT_ID=
DUO_CLIENT_SECRET=
DUO_API_HOST=api-XXXXXXXX.duosecurity.com

# 启用 Duo 时必须配, 防止外部域名在你员工手机上乱触发 Duo 页面.
ALLOWED_EMAIL_DOMAINS=example.org,example.com,example.net

# ===== 访客码管理后台 (可选) =====
# /admin 准入两种方式, 任一成立即通过, 可单独用也可共用:
#   - ADMIN_EMAILS      UPN 白名单 (直接列人, 改动要重启容器)
#   - ADMIN_GROUP_IDS   Entra Security Group 的 Object ID (GUID) 列表,
#                       组里的人自动有 admin 权限, 不用改 env
# 两个都为空 = /admin 后台完全关闭.
ADMIN_EMAILS=you@example.org
# Entra Security Group Object ID (GUID). 入口: Entra Admin Center → Groups →
# 选目标组 → Overview → 复制 "Object ID". 前提: App Registration 已加 groups claim.
#ADMIN_GROUP_IDS=00000000-0000-0000-0000-000000000000

# 持久化文件统一写到容器内 /data/ 下 (访客码 / MAC 封禁 / iKuai 策略 /
# 限流历史 / 事件日志), 路径在代码里固定. docker-compose.yml 已经把 /data
# bind-mount 到 ./data/, 想换位置改 volume 那一行即可, 不需要在这里配任何 env.

# ===== 限流 / 防滥用 (全部可选, 留空走代码默认) =====
# 规则 1: /auth/start 按邮箱失败计数, 双窗口, 成功回调清零. 防 MFA 轰炸.
#AUTH_EMAIL_FAILS_SHORT=5         # 短窗口上限
#AUTH_EMAIL_WINDOW_SHORT=3m       # 短窗口长度 (支持 s/m/h)
#AUTH_EMAIL_FAILS_LONG=20
#AUTH_EMAIL_WINDOW_LONG=1h

# 规则 5: /auth/guest-code 按 session 里的 MAC 失败计数, 成功清零.
#GUEST_CODE_MAC_FAILS=6
#GUEST_CODE_MAC_WINDOW=30m

# 规则 6: 单 IP 跨端点累计失败超限 → 短时冷却. IP 不做永久封禁.
#IP_FAILS_LIMIT=20
#IP_FAILS_WINDOW=5m
#IP_BAN_DURATION=2m                # 冷却时长
#IP_BAN_ESCALATE_AT=999999         # 基本等于不升级永久

# 账号枚举防护: /auth/start → opaque token → /auth/proceed 中转.
#AUTH_PROCEED_TTL=5m

# ===== 事件日志保留期 =====
# 默认 7 天, 超过会被后台 gc 掉 (重写整个 JSONL).
# 想 tail -f 看实时流量很方便.
#EVENT_LOG_RETENTION_DAYS=7

# ===== Portal 自身 =====
# PUBLIC_URL 必须和实际可达的对外地址完全一致 (包括端口号, 因为 Entra 回调要精确匹配).
#   模式 A: https://wifi.login.example.com        (外部反代跑 443)
#   模式 B: https://wifi.login.example.com:28081  (Caddy 跑 28081)
PUBLIC_URL=https://wifi.login.example.com

# Portal 进程监听.
#   Docker 部署 (模式 A/B/C): 0.0.0.0:28080, compose 映射到宿主 127.0.0.1:28080
#   裸二进制 + systemd (模式 D): 直接 127.0.0.1:28080, 反代访问, 别公开端口
LISTEN_ADDR=0.0.0.0:28080

# 持久化文件根目录. 默认 /data 适合容器 (docker-compose 把 /data bind-mount 到 ./data).
# 裸二进制 + systemd 部署改成 /var/lib/wifi-portal (跟 systemd unit 的 ReadWritePaths 对齐).
#DATA_DIR=/data

# 容器时区. 默认 UTC. admin 后台 datetime-local 输入按这里解析:
#   TZ=UTC                 → admin 填 "18:00" 当 18:00 UTC
#   TZ=Asia/Shanghai       → admin 填 "18:00" 当 18:00 北京时间
# 改这里同时影响日志时间戳、CSV 导出时间列、admin 列表显示.
#TZ=UTC

# 是否信任反代 header (X-Real-IP / X-Forwarded-For) 作为客户端 IP. 默认 true.
# 生产部署 (反代终结 TLS, Portal 端口不直暴) 保持 true. 若 Portal 端口直接暴露公网,
# 务必置 false — 否则攻击者可任意伪造 IP 绕过 IP 限流和永久封禁.
# 反代场景推荐配 X-Real-IP $remote_addr (nginx) / header_up X-Real-IP {remote_host} (Caddy).
# X-Forwarded-For 解析时取**最右**那一段 (反代 append 的真客户端 IP), 攻击者伪造的部分被推到左侧.
#TRUST_PROXY=true

# HMAC cookie 签名密钥. openssl rand -hex 32 生成一次. 多站点想共享 admin cookie
# (SSO 登一次跨站点都认) 就填同一个值; 要隔离就各自生成.
SESSION_SECRET=REPLACE_ME_WITH_openssl_rand_hex_32

# ===== 品牌化 =====
BRAND_NAME=Kazuha Hub
BRAND_COLOR=#2563eb
BRAND_LOGO_URL=
