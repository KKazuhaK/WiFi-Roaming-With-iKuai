# .env.example
# 拷贝这个文件成 .env, 填入真实值, 然后:
#   chmod 600 .env          # 只允许你自己读
#   docker compose up -d    # 起服务
#
# .env 里的 Secret 不能进 git. .gitignore 已经忽略 *.env 但不排除 .env.example

# ===== Entra ID (Azure AD) =====
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== iKuai 云自定义认证 =====
IKUAI_APPKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

IKUAI_IP_KEYS=user_ip,ip,ipaddr
IKUAI_MAC_KEYS=user_mac,mac,usrmac,devmac

# 仅当 Phase 4 发现某种固件只接受 http 或要走路由器 LAN IP 时才改.
#IKUAI_WEBAUTH_URL=https://portal.ikuai8-wifi.com/Action/webauth-up
#IKUAI_CUSTOM_NAME=kazuha-hub
#IKUAI_RELEASE_TYPE=1
IKUAI_USER_ID_PREFIX=Kazuha_Hub

# ===== Duo 免密推送 (可选, 三个值全空 = 禁用) =====
# Duo Admin Panel → Applications → Protect an Application → "Auth API" 取.
DUO_IKEY=
DUO_SKEY=
DUO_API_HOST=api-XXXXXXXX.duosecurity.com

# 启用 Duo 时必须配, 防止外部域名乱触发推送.
ALLOWED_EMAIL_DOMAINS=example.org,example.com,example.net

#DUO_PUSH_TIMEOUT=60

# ===== 访客码管理后台 (可选, 空 = 禁用整个访客码流程) =====
# 这些邮箱的人用 Entra 登录 /admin 后可以管理访客码.
# 逗号分隔, 大小写不敏感. 留空则 /admin 不可用, 用户侧的"访客码登录"按钮也不显示.
ADMIN_EMAILS=you@example.org

# ===== Portal 自身 =====
PUBLIC_URL=https://wifi.login.example.com
LISTEN_ADDR=0.0.0.0:28080
SESSION_SECRET=REPLACE_ME_WITH_openssl_rand_hex_32

# ===== 品牌化 =====
BRAND_NAME=Kazuha Hub
BRAND_COLOR=#2563eb
BRAND_LOGO_URL=
