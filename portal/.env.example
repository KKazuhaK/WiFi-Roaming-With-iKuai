# .env.example
# 拷贝成 .env (放在 docker-compose.yml 同级), chmod 600 .env, docker compose up -d --build
#
# 这一份文件同时覆盖两种部署模式:
#   - 模式 A: 外部反代 (aaPanel Nginx / 其它), Caddy 不启动 — 下面 COMPOSE_PROFILES 留空
#   - 模式 B: 内置 Caddy 做 TLS + DNS-01, 把 COMPOSE_PROFILES=caddy 打开即可

# ============================================================
# 部署模式开关
# ============================================================
# 留空 = 模式 A (只跑 Portal, 外部反代处理 TLS).
# 设成 caddy = 模式 B (Portal + Caddy, Caddy 自动 Cloudflare DNS-01 拿证书).
#COMPOSE_PROFILES=caddy

# ===== 只有模式 B (Caddy) 会用到的变量 =====

# Cloudflare API Token, 只给 Zone:DNS:Edit 权限, 限定到 kazuhahub.com zone.
# CF Dashboard → My Profile → API Tokens → Create Token → Edit zone DNS 模板.
# 4 个站点可以复用同一个 token.
CLOUDFLARE_API_TOKEN=

# LE / ZeroSSL 账号注册邮箱, 收到期提醒用.
ACME_EMAIL=me@kazuha.org

# 对外域名 (决定证书申请哪个 + Caddy 反代的 virtual host).
PORTAL_HOSTNAME=wifi.login.kazuhahub.com

# Caddy 监听的 HTTPS 端口. 28081 是默认, 避开 443 以免跟宿主其他服务冲突.
# 改这里同步改 PUBLIC_URL 和 Entra Redirect URI 和 iKuai captive URL.
PORTAL_HTTPS_PORT=28081

# ============================================================
# Portal 本体配置 (两种模式都要填)
# ============================================================

# ===== Entra ID (Azure AD) =====
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== iKuai 云自定义认证 =====
IKUAI_APPKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

IKUAI_IP_KEYS=user_ip,ip,ipaddr
IKUAI_MAC_KEYS=user_mac,mac,usrmac,devmac
#IKUAI_WEBAUTH_URL=https://portal.ikuai8-wifi.com/Action/webauth-up
#IKUAI_CUSTOM_NAME=kazuha-hub
#IKUAI_RELEASE_TYPE=1
IKUAI_USER_ID_PREFIX=Kazuha_Hub

# ===== Duo 集成 (可选, 五个值全空则禁用 Duo 分流) =====
#
# 需要在 Duo Admin Panel 创建 **两个** Application:
#   1. "Auth API"  → DUO_IKEY / DUO_SKEY                (preauth 探测用户在不在 Duo)
#   2. "Web SDK"   → DUO_CLIENT_ID / DUO_CLIENT_SECRET  (Universal Prompt 2FA)
# 两个共享同一 API hostname. 五个字段全填或全空.
DUO_IKEY=
DUO_SKEY=
DUO_CLIENT_ID=
DUO_CLIENT_SECRET=
DUO_API_HOST=api-XXXXXXXX.duosecurity.com

# 启用 Duo 时必须配, 防止外部域名在你员工手机上乱触发 Duo 页面.
ALLOWED_EMAIL_DOMAINS=kazuha.org,kazuhahub.com,kazuhahub.cn

# ===== 访客码管理后台 (可选) =====
# /admin 准入两种方式, 任一成立即通过, 可单独用也可共用:
#   - ADMIN_EMAILS      UPN 白名单 (直接列人, 改动要重启容器)
#   - ADMIN_GROUP_IDS   Entra Security Group 的 Object ID (GUID) 列表,
#                       组里的人自动有 admin 权限, 不用改 env
# 两个都为空 = /admin 后台完全关闭.
ADMIN_EMAILS=me@kazuha.org
# Entra Security Group Object ID (GUID). 入口: Entra Admin Center → Groups →
# 选目标组 → Overview → 复制 "Object ID". 前提: App Registration 已加 groups claim.
#ADMIN_GROUP_IDS=00000000-0000-0000-0000-000000000000

# 访客码持久化文件路径. 留空 = 纯内存, 容器一挂就丢.
# /data/guest-codes.json 写在容器内部, restart 能活, up -d --build 会丢.
# 要跨重建保住, 去 docker-compose.yml 里把 volume 挂载那两行取消注释.
#GUEST_CODES_PATH=/data/guest-codes.json

# ===== 限流 / 防滥用 (全部可选, 留空走代码默认) =====
# 规则 1: /auth/start 按邮箱失败计数, 双窗口, 成功回调清零. 防 MFA 轰炸.
#AUTH_EMAIL_FAILS_SHORT=5         # 短窗口上限
#AUTH_EMAIL_WINDOW_SHORT=3m       # 短窗口长度 (支持 s/m/h)
#AUTH_EMAIL_FAILS_LONG=20
#AUTH_EMAIL_WINDOW_LONG=1h

# 规则 5: /auth/guest-code 按 session 里的 MAC 失败计数, 成功清零.
#GUEST_CODE_MAC_FAILS=10
#GUEST_CODE_MAC_WINDOW=1h

# 规则 6: 单 IP 跨端点累计失败超限 → 封禁一段时间.
#IP_FAILS_LIMIT=30
#IP_FAILS_WINDOW=1h
#IP_BAN_DURATION=1h

# 账号枚举防护: /auth/start → opaque token → /auth/proceed 中转.
#AUTH_PROCEED_TTL=5m

# ===== Portal 自身 =====
# PUBLIC_URL 必须和实际可达的对外地址完全一致 (包括端口号, 因为 Entra 回调要精确匹配).
#   模式 A: https://wifi.login.kazuhahub.com        (外部反代跑 443)
#   模式 B: https://wifi.login.kazuhahub.com:28081  (Caddy 跑 28081)
PUBLIC_URL=https://wifi.login.kazuhahub.com

# Portal 进程监听. 容器内部 0.0.0.0:28080, Docker 把它映射到宿主 127.0.0.1:28080.
LISTEN_ADDR=0.0.0.0:28080

# HMAC cookie 签名密钥. openssl rand -hex 32 生成一次. 多站点想共享 admin cookie
# (SSO 登一次跨站点都认) 就填同一个值; 要隔离就各自生成.
SESSION_SECRET=REPLACE_ME_WITH_openssl_rand_hex_32

# ===== 品牌化 =====
BRAND_NAME=Kazuha Hub
BRAND_COLOR=#2563eb
BRAND_LOGO_URL=
