# .env.example
# 拷贝成 .env, 填真实值, chmod 600 .env, docker compose up -d

# ===== Entra ID (Azure AD) =====
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== iKuai 云自定义认证 =====
IKUAI_APPKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

IKUAI_IP_KEYS=user_ip,ip,ipaddr
IKUAI_MAC_KEYS=user_mac,mac,usrmac,devmac
#IKUAI_WEBAUTH_URL=https://portal.ikuai8-wifi.com/Action/webauth-up
#IKUAI_CUSTOM_NAME=kazuha-hub
#IKUAI_RELEASE_TYPE=1
IKUAI_USER_ID_PREFIX=Kazuha_Hub

# ===== Duo 集成 (可选, 五个值全空则禁用 Duo 分流) =====
#
# 需要在 Duo Admin Panel 创建 **两个** Application:
#
#   1. "Auth API" application
#      用途: 仅 preauth 探测用户是否在 Duo (决定流量走 Duo 还是 Entra)
#      拿到: Integration key + Secret key
#      → DUO_IKEY / DUO_SKEY
#
#   2. "Web SDK" application
#      用途: 用户实际 2FA 的 Universal Prompt 页面 (用户在 Duo 的 UI 里选设备)
#      Redirect URI 必须填: https://wifi.login.example.com/auth/duo-callback
#      拿到: Client ID + Client secret
#      → DUO_CLIENT_ID / DUO_CLIENT_SECRET
#
# 两个 Application 共用同一个 API hostname (= DUO_API_HOST).
# 五个字段要么全填 要么全空.
DUO_IKEY=
DUO_SKEY=
DUO_CLIENT_ID=
DUO_CLIENT_SECRET=
DUO_API_HOST=api-XXXXXXXX.duosecurity.com

# 启用 Duo 时必须配, 防止外部域名在你员工手机上乱触发 Duo 页面.
ALLOWED_EMAIL_DOMAINS=example.org,example.com,example.net

# ===== 访客码管理后台 (可选) =====
ADMIN_EMAILS=you@example.org

# 访客码持久化文件路径. 留空 = 纯内存, 容器一挂就丢.
# 设为 /data/guest-codes.json 后默认落在容器内部, 行为:
#   restart / stop+start / VPS 重启 → 保留
#   up -d --build / down / rm       → 会丢 (容器被替换)
# 想跨重建也保住数据, 去 docker-compose.yml 里开 volume 挂载 (注释里写了).
#GUEST_CODES_PATH=/data/guest-codes.json

# ===== 限流 / 防滥用 (全部可选, 留空走下方默认) =====
# 规则 1: /auth/start 按邮箱失败计数, 双窗口, 成功回调清零.
# 防 Duo MFA 轰炸 — 任何攻击者最多对单一受害者造成 3 次推送/5 分钟.
#AUTH_EMAIL_FAILS_SHORT=3         # 短窗口上限
#AUTH_EMAIL_WINDOW_SHORT=5m       # 短窗口长度 (支持 s/m/h)
#AUTH_EMAIL_FAILS_LONG=10         # 长窗口上限
#AUTH_EMAIL_WINDOW_LONG=1h        # 长窗口长度

# 规则 5: /auth/guest-code 按 session 里的 MAC 失败计数, 成功清零.
# 防暴力猜码. 一个设备 1 小时内只能猜错 10 次.
#GUEST_CODE_MAC_FAILS=10
#GUEST_CODE_MAC_WINDOW=1h

# 规则 6: 单 IP 跨端点累计失败超限 → 封禁一段时间.
# 包括 /auth/start 和 /auth/guest-code 的各类失败 (包括触发上面的限流本身).
#IP_FAILS_LIMIT=30                # 失败阈值
#IP_FAILS_WINDOW=1h               # 计数窗口
#IP_BAN_DURATION=1h               # 触发后封禁时长

# 账号枚举防护: /auth/start 返回 opaque token, /auth/proceed?token=X 才 302 到
# 真实目的 (Duo/Entra). token 存活时间 — 太短会让慢速用户点击失败.
#AUTH_PROCEED_TTL=5m

# ===== Portal 自身 =====
PUBLIC_URL=https://wifi.login.example.com
LISTEN_ADDR=0.0.0.0:28080
SESSION_SECRET=REPLACE_ME_WITH_openssl_rand_hex_32

# ===== 品牌化 =====
BRAND_NAME=Kazuha Hub
BRAND_COLOR=#2563eb
BRAND_LOGO_URL=
