# Caddyfile
# TLS certificates are issued through Cloudflare DNS-01 challenge; no public port reachability needed.
# This is the key for LAN deployments: the box only has a LAN IP, but the certificate is still issued
# by a real CA, so browsers do not warn.
#
# Reverse proxy only to the portal service on the same compose network; Portal is not exposed on host ports.

{
    # Email for LE / ZeroSSL account registration and certificate expiry reminders.
    email {$ACME_EMAIL}
}

{$PORTAL_HOSTNAME}:{$PORTAL_HTTPS_PORT} {
    # DNS-01 via Cloudflare. CLOUDFLARE_API_TOKEN only needs Zone:DNS:Edit plus Zone:Zone:Read,
    # scoped to the kazuhahub.com zone. DNS-01 does not need public 80/443 reachability.
    tls {
        dns cloudflare {env.CLOUDFLARE_API_TOKEN}
    }

    # Reverse proxy to the portal container. Container name portal equals the compose service name,
    # and Caddy resolves it via DNS, so no IP is needed.
    reverse_proxy portal:28080 {
        # Used by Portal ratelimit.go clientIP().
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
        header_up Host {host}
    }

    # Caddy's default log level is reasonable; explicitly write access logs to stdout.
    log {
        output stdout
        format console
    }
}
