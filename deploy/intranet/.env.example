# .env.example — 内网方案
# 拷贝成 .env, chmod 600, 填值, docker compose up -d --build
#
# 这里的 env 分两段:
#   - Caddy 专用: CLOUDFLARE_API_TOKEN / ACME_EMAIL / PORTAL_HOSTNAME
#   - Portal 专用: 所有原本 portal/.env.example 里的变量 (TENANT_ID / CLIENT_ID 等)
#
# 两段都在同一个 .env, docker compose 自动区分 (各 service 只读自己声明的).

# ========== Caddy 专用 ==========

# Cloudflare API Token, 只给 Zone:DNS:Edit + Zone:Zone:Read 权限.
# 创建位置: CF Dashboard → 右上头像 → My Profile → API Tokens → Create Token
# → "Edit zone DNS" 模板 → Zone Resources 选 Include → Specific zone → kazuhahub.com
CLOUDFLARE_API_TOKEN=

# LE / ZeroSSL 账号邮箱, 用于续签提醒. 随便填个你的邮箱.
ACME_EMAIL=me@kazuha.org

# 对外域名. 如果你开了多站点并且想每个站点一个子域 (wifi-a.login..., wifi-b...)
# 记得每个 .env 填不同值 + CF 上各自加 DNS 记录以便 DNS-01 验证.
PORTAL_HOSTNAME=wifi.login.kazuhahub.com

# ========== Portal 专用 ==========
# (直接从 portal/.env.example 拷贝, 几个说明 refer 原 README)

# --- Entra ID (Azure AD) ---
TENANT_ID=00000000-0000-0000-0000-000000000000
CLIENT_ID=00000000-0000-0000-0000-000000000000
CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- iKuai 云自定义认证 ---
IKUAI_APPKEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
IKUAI_IP_KEYS=user_ip,ip,ipaddr
IKUAI_MAC_KEYS=user_mac,mac,usrmac,devmac
#IKUAI_WEBAUTH_URL=https://portal.ikuai8-wifi.com/Action/webauth-up
#IKUAI_CUSTOM_NAME=kazuha-hub
#IKUAI_RELEASE_TYPE=1
IKUAI_USER_ID_PREFIX=Kazuha_Hub

# --- Duo (可选, 五字段全填或全空) ---
DUO_IKEY=
DUO_SKEY=
DUO_CLIENT_ID=
DUO_CLIENT_SECRET=
DUO_API_HOST=api-XXXXXXXX.duosecurity.com
ALLOWED_EMAIL_DOMAINS=kazuha.org,kazuhahub.com,kazuhahub.cn

# --- Admin 后台 ---
# 两种方式任一成立即通过, 多站点可以共用同一份配置 (都指向同一个 Entra 组)
ADMIN_EMAILS=me@kazuha.org
#ADMIN_GROUP_IDS=00000000-0000-0000-0000-000000000000

# 访客码持久化. 默认挂到 ./data, 宿主机可直接 cat / 备份 /opt/wifi-portal-intranet/data/
GUEST_CODES_PATH=/data/guest-codes.json

# --- Portal 自身 ---
# 注意: PUBLIC_URL 必须和 PORTAL_HOSTNAME 对上 (Entra/Duo 回调要用)
PUBLIC_URL=https://wifi.login.kazuhahub.com

# SESSION_SECRET 用 openssl rand -hex 32 生成.
# 多站点**各自**生成一份独立的, 这样 site A 的 admin cookie 在 site B 不能用 — 推荐.
# 如果希望 admin 在任意站点登一次就四个都通, 填同一个值.
SESSION_SECRET=REPLACE_ME_WITH_openssl_rand_hex_32

# --- 品牌化 ---
BRAND_NAME=Kazuha Hub
BRAND_COLOR=#2563eb
BRAND_LOGO_URL=

# --- 限流 (全部可选, 留空走代码默认, 细节见仓库根 README 的 "安全 / 防滥用" 段) ---
#AUTH_EMAIL_FAILS_SHORT=3
#AUTH_EMAIL_WINDOW_SHORT=5m
#AUTH_EMAIL_FAILS_LONG=10
#AUTH_EMAIL_WINDOW_LONG=1h
#GUEST_CODE_MAC_FAILS=10
#GUEST_CODE_MAC_WINDOW=1h
#IP_FAILS_LIMIT=30
#IP_FAILS_WINDOW=1h
#IP_BAN_DURATION=1h
#AUTH_PROCEED_TTL=5m
